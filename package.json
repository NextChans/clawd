{
  "name": "clawd",
  "private": true,
  "version": "0.16.1",
  "type": "module",
  "description": "Cute floating cat that shows Claude Code usage on macOS and Windows",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:universal": "tauri build --target universal-apple-darwin",
    "tauri:build:windows": "tauri build",
    "release:local": "npm run tauri:build:universal && open src-tauri/target/universal-apple-darwin/release/bundle/dmg/",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2",
    "framer-motion": "^12.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
