{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clawd",
  "version": "0.1.0",
  "identifier": "com.chani.clawd",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "cat",
        "title": "clawd",
        "url": "index.html",
        "width": 160,
        "height": 160,
        "minWidth": 160,
        "minHeight": 160,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "acceptFirstMouse": false,
        "titleBarStyle": "Transparent"
      },
      {
        "label": "details",
        "title": "clawd · usage",
        "url": "index.html?window=details",
        "width": 340,
        "height": 460,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
